# Autosclaw Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# Or run the AI-assisted setup with Claude Code:
#   /setup

# ─── Required ────────────────────────────────────────────────────────

# Anthropic API key for Claude agents
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Admin Account (seeded on first run) ─────────────────────────────

ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ─── Authentication ──────────────────────────────────────────────────

# Secret used to sign JWT tokens (24h expiry)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, a random secret is generated on each start (invalidates sessions on restart)
JWT_SECRET=

# ─── Server ──────────────────────────────────────────────────────────

# Port the manager server and dashboard listen on
PORT=4000

# Docker bridge gateway IP (auto-detected on Linux via `ip route`)
# Only set this if auto-detection fails
# MANAGER_HOST=172.17.0.1

# ─── Optional Features ──────────────────────────────────────────────

# Allow new users to self-register via the dashboard
ALLOW_REGISTRATION=false

# Logging verbosity: debug, info, warn, error
LOG_LEVEL=info

# Directory for log files (with rotation at 10 MB, keeps 5 files)
# Leave empty to log to stdout only
# LOG_DIR=/var/log/autosclaw

# ─── GitHub Integration ─────────────────────────────────────────────

# GitHub personal access token
# Gives agents access to clone, push, open PRs, and self-modify repositories
# GH_TOKEN=ghp_...
